# ── 공통 ─────────────────────────────────────────────────────────
# Defaults below target Sepolia, but the app now follows CHAIN_ID dynamically.
CHAIN_ID=11155111
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
FAUCET_ADDRESS=0xYOUR_FAUCET_CONTRACT_ADDRESS

# ── API ───────────────────────────────────────────────────────────
PORT=3001
DATABASE_URL=postgresql://faucet:changeme@localhost:5432/faucet
IP_HMAC_SECRET=change-this-to-a-random-secret-32-chars
FRONTEND_URL=https://your-domain.com
RATE_LIMIT_WINDOW_SECONDS=600
RATE_LIMIT_MAX_CHALLENGE=10
RATE_LIMIT_MAX_CLAIM=5

# ── Worker (이 파일은 worker 컨테이너에만 주입) ────────────────────
RELAYER_PRIVATE_KEY=0xYOUR_RELAYER_PRIVATE_KEY
CONFIRMATIONS_REQUIRED=1
BROADCAST_TIMEOUT_SECONDS=120
POLL_INTERVAL_MS=5000
LEASE_DURATION_SECONDS=120
MAX_FEE_PER_GAS_GWEI=50

# ── Infra ────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme
WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# ── Frontend (NEXT_PUBLIC_ 은 브라우저에 노출됨) ──────────────────
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_FAUCET_ADDRESS=0xYOUR_FAUCET_CONTRACT_ADDRESS
NEXT_PUBLIC_API_BASE_URL=/api/v1
# Optional override. Leave blank to derive explorer from CHAIN_ID metadata.
NEXT_PUBLIC_RPC_EXPLORER_BASE_URL=
# Optional RPC URL for unknown chains (non-Sepolia/Holesky/Hardhat).
NEXT_PUBLIC_RPC_URL=
# Token symbol shown in UI. Defaults to TTK if unset.
NEXT_PUBLIC_TOKEN_SYMBOL=TTK
# Required. Must be explicitly "true" or "false".
NEXT_PUBLIC_IS_TESTNET=true
# Optional for local `pnpm --filter @eip712-faucet/frontend dev/build`.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
