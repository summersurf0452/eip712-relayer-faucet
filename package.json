{
  "name": "eip712-relayer-faucet",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev:api": "pnpm --filter @eip712-faucet/api dev",
    "dev:worker": "pnpm --filter @eip712-faucet/worker dev",
    "dev:frontend": "pnpm --filter @eip712-faucet/frontend dev",
    "db:migrate": "pnpm --filter @eip712-faucet/api prisma:migrate",
    "db:generate": "pnpm --filter @eip712-faucet/api prisma:generate",
    "test:contracts": "cd contracts && forge test",
    "lint": "pnpm -r lint"
  }
}
